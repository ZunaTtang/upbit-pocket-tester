# Copy to .env and edit. .env is git-ignored.

# Used to derive the encryption key for API secret_keys at rest.
# Set to a long random string. Changing it makes previously stored secrets unreadable.
APP_SECRET=change-me-to-a-long-random-string

# Upbit REST base URL. Override only if Upbit changes hosts.
UPBIT_BASE_URL=https://api.upbit.com

# SQLite location. Leave unset to use <project-root>/data/workbench.db (recommended).
# DB_PATH=./data/workbench.db

# Backend bind + CORS origin for the Vite dev server.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Upstream request timeout (seconds).
REQUEST_TIMEOUT=15
